cat > .env.example << 'EOF'
# Copy this file to .env and fill in your own values

# Path to your Google service account JSON (relative to project root)
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json

# The ID of the Google Sheet to write to (the long string in the sheet's URL)
GOOGLE_SHEET_ID=your_sheet_id_here

# Worksheet/tab name within the sheet
GOOGLE_WORKSHEET_NAME=Sheet1

# Time of day to run the scheduled scrape (24h format, local time)
SCHEDULE_TIME=03:00
EOF